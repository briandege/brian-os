{
  "name": "strontium-os",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "electron": "NODE_ENV=development electron .",
    "electron:dev": "concurrently \"next dev --turbopack --port 3002\" \"wait-on http://localhost:3002 && ELECTRON_PORT=3002 npm run electron\"",
    "electron:build": "next build --turbopack && next export && electron-builder"
  },
  "build": {
    "appId": "com.briandege.strontium-os",
    "productName": "strontium.os",
    "directories": { "output": "dist" },
    "files": ["electron/**/*", "out/**/*", "public/**/*"],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    }
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "next": "15.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
