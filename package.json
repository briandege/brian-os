{
  "name": "strontium-os",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",

    "electron": "cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently \"next dev --turbopack --port 3002\" \"wait-on http://localhost:3002 && cross-env NODE_ENV=development ELECTRON_PORT=3002 electron .\"",

    "build:electron": "cross-env NEXT_BUILD_TARGET=electron next build",
    "dist":       "npm run build:electron && electron-builder",
    "dist:mac":   "npm run build:electron && electron-builder --mac",
    "dist:win":   "npm run build:electron && electron-builder --win",
    "dist:linux": "npm run build:electron && electron-builder --linux",
    "dist:all":   "npm run build:electron && electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.briandege.strontium-os",
    "productName": "strontium.os",
    "copyright": "Copyright © 2026 Brian Ndege",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "!node_modules"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64", "arm64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "strontium.os"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64"] },
        { "target": "rpm",      "arch": ["x64"] }
      ],
      "category": "Development",
      "description": "strontium.os — a portfolio OS by Brian Ndege",
      "maintainer": "Brian Ndege"
    }
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "next": "15.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
