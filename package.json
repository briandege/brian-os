{
  "name": "strontium-os",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty",
    "start": "concurrently \"next dev --turbopack --port 3002\" \"wait-on http://localhost:3002 && cross-env NODE_ENV=development ELECTRON_PORT=3002 electron .\"",
    "dev": "next dev --turbopack",
    "lint": "eslint",
    "build:next": "cross-env NEXT_BUILD_TARGET=electron next build",
    "build": "npm run build:next && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config.mac.identity=null",
    "build:mac": "npm run build:next && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --config.mac.identity=null",
    "build:win": "npm run build:next && electron-builder --win",
    "build:linux": "npm run build:next && electron-builder --linux",
    "build:all": "npm run build:next && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --win --linux --config.mac.identity=null"
  },
  "build": {
    "appId": "com.briandege.strontium-os",
    "productName": "strontium.os",
    "copyright": "Copyright © 2026 Brian Ndege",
    "asar": true,
    "asarUnpack": ["**/node_modules/node-pty/**", "**/node_modules/systeminformation/**"],
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "strontium.os"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "description": "strontium.os — a portfolio OS by Brian Ndege",
      "maintainer": "Brian Ndege"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "next": "15.5.14",
    "node-pty": "^1.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "systeminformation": "^5.31.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
